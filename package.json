{
  "name": "lending-protocol",
  "version": "1.0.0",
  "description": "A modular decentralized lending protocol written in Solidity using Foundry, featuring collateralized borrowing, interest rate models, and liquidation logic.",
  "keywords": [
    "defi",
    "lending-protocol",
    "solidity",
    "foundry",
    "smart-contracts",
    "ethereum",
    "evm",
    "collateralized-loans",
    "borrowing",
    "lending",
    "liquidation",
    "interest-rates",
    "web3",
    "blockchain",
    "protocol"
  ],
  "homepage": "https://github.com/Cohort-8-BuidL/Lending-Protocol#readme",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,sol}\"",
    "solhint": "solhint \"contracts/**/*.sol\"",
    "solhint:fix": "solhint --fix \"contracts/**/*.sol\""
  },
  "bugs": {
    "url": "https://github.com/Cohort-8-BuidL/Lending-Protocol/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cohort-8-BuidL/Lending-Protocol.git"
  },
  "license": "MIT",
  "author": "Cohort 8",
  "type": "commonjs",
  "main": "index.ts",
  "directories": {
    "lib": "lib"
  },
  "packageManager": "pnpm@10.25.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "solhint": "^6.0.3"
  }
}
